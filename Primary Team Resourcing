<!DOCTYPE html>
<html lang="en-AU">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Primary Design Team — Resource Schedule | CPP</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;0,800;1,500&display=swap" rel="stylesheet">
<style>
:root{
  --red:#9E053B;          /* PMS 194 C — headings, call-outs, firm */
  --red-deep:#7d0430;
  --ink:#000000;          /* PMS Black */
  --gray11:#4D4D4D;       /* Cool Gray 11 */
  --gray:#707070;
  --line:#DEDEDE;
  --f2:#F2F2F2;
  --f9:#F9F9F9;
  --white:#FFFFFF;
  --gold:#DFB200;         /* secondary — tenders / indicative */
  --peach:#F2BB97;        /* secondary — highlight */
  --peach-lt:#F4DDCE;     /* secondary — highlight light */
  --leftW:268px;
  --rowH:34px;
  --grpH:44px;
  --headH:58px;
  --sh:0 1px 2px rgba(0,0,0,.08),0 6px 20px rgba(0,0,0,.06);
  --focus:0 0 0 3px rgba(158,5,59,.35);
}
*{box-sizing:border-box}
html,body{margin:0;height:100%}
body{
  font-family:'Montserrat',system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
  color:var(--ink);background:var(--white);
  font-size:14px;line-height:1.45;-webkit-font-smoothing:antialiased;
  display:flex;flex-direction:column;height:100vh;overflow:hidden;
}
.tnum{font-variant-numeric:tabular-nums;letter-spacing:.2px}
button{font-family:inherit}
:focus-visible{outline:none;box-shadow:var(--focus);border-radius:6px}

/* ---------- Masthead ---------- */
.mast{display:flex;align-items:center;gap:16px;padding:14px 20px;border-bottom:1px solid var(--line);background:var(--white);flex:0 0 auto}
.mark{flex:0 0 auto;display:flex;align-items:center}
.mark img{display:block;height:44px;width:auto}
.mast-txt{display:flex;flex-direction:column;line-height:1.05}
.eyebrow{font-size:10.5px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gray)}
.mast h1{margin:2px 0 0;font-size:23px;font-weight:800;letter-spacing:-.01em}
.mast h1 b{color:var(--red);font-weight:800}
.mast-spacer{flex:1}
.mast-meta{text-align:right;font-size:11px;color:var(--gray);letter-spacing:.04em}
.mast-meta b{color:var(--ink);font-weight:700}

/* ---------- Toolbar ---------- */
.toolbar{display:flex;align-items:center;gap:10px;flex-wrap:wrap;padding:10px 20px;border-bottom:1px solid var(--line);background:var(--f9);flex:0 0 auto}
.tb-group{display:flex;align-items:center;gap:6px}
.tb-label{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--gray);margin-right:2px}
.seg{display:inline-flex;border:1px solid var(--line);border-radius:8px;overflow:hidden;background:var(--white)}
.seg button{border:0;background:transparent;padding:7px 12px;font-size:12px;font-weight:600;color:var(--gray11);cursor:pointer;border-right:1px solid var(--line)}
.seg button:last-child{border-right:0}
.seg button.on{background:var(--red);color:#fff}
.seg button:hover:not(.on){background:var(--f2)}
.btn{border:1px solid var(--line);background:var(--white);color:var(--ink);padding:7px 13px;font-size:12px;font-weight:600;border-radius:8px;cursor:pointer;display:inline-flex;align-items:center;gap:6px}
.btn:hover{background:var(--f2)}
.btn.primary{background:var(--red);border-color:var(--red);color:#fff}
.btn.primary:hover{background:var(--red-deep)}
.btn svg{display:block}
.spacer{flex:1}
.legend{display:flex;align-items:center;gap:14px;font-size:11px;color:var(--gray11);flex-wrap:wrap}
.lg{display:inline-flex;align-items:center;gap:6px}
.sw{width:14px;height:10px;border-radius:2px;display:inline-block}
.dref{width:11px;height:11px;transform:rotate(45deg);display:inline-block;border:1.5px solid var(--red);background:#fff}
.dref.firm{background:var(--red);border-color:var(--red)}

/* ---------- Board ---------- */
.viewport{flex:1 1 auto;overflow:auto;position:relative;background:var(--white)}
.board{position:relative}
.thead{position:sticky;top:0;z-index:30;height:var(--headH);display:flex;width:100%;background:var(--white);border-bottom:1.5px solid var(--gray11)}
.thead .corner{position:sticky;left:0;z-index:5;width:var(--leftW);flex:0 0 var(--leftW);background:var(--white);border-right:1.5px solid var(--gray11);display:flex;align-items:flex-end;padding:0 14px 8px}
.corner .corner-title{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--gray)}
.taxis{position:relative;flex:0 0 auto}
.month{position:absolute;top:0;bottom:0;border-left:1px solid var(--line);padding:6px 0 0 8px;overflow:hidden}
.month .m-name{font-size:11px;font-weight:700;color:var(--ink);text-transform:uppercase;letter-spacing:.06em;white-space:nowrap}
.month.alt{background:var(--f9)}
.week{position:absolute;top:26px;bottom:0;border-left:1px dashed #e7e7e7;font-size:9px;color:var(--gray);padding:2px 0 0 3px;white-space:nowrap}

.rows{position:relative}
.grp{display:flex;width:100%;height:var(--grpH);align-items:stretch;border-bottom:1px solid var(--line);background:var(--f2)}
.grp .g-label{position:sticky;left:0;z-index:15;width:var(--leftW);flex:0 0 var(--leftW);background:var(--f2);border-right:1.5px solid var(--gray11);display:flex;flex-direction:column;justify-content:center;padding:5px 14px;gap:3px;cursor:pointer}
.grp .g-label:hover{background:#ededed}
.g-name{font-size:13px;font-weight:800;letter-spacing:-.01em;display:flex;align-items:center;gap:7px}
.g-name .g-nm{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.g-name .cap{font-size:10px;font-weight:700;color:#fff;background:var(--gray);border-radius:20px;padding:1px 7px;flex:0 0 auto}
.chev{border:0;background:none;padding:0;width:16px;height:16px;flex:0 0 16px;display:flex;align-items:center;justify-content:center;color:var(--gray11);cursor:pointer}
.chev svg{width:11px;height:11px;transition:transform .16s}
.chev.closed svg{transform:rotate(-90deg)}
@media (prefers-reduced-motion:reduce){.chev svg{transition:none}}
.util{display:flex;align-items:center;gap:7px}
.util-track{position:relative;flex:1;height:6px;border-radius:4px;background:#e2e2e2;overflow:hidden}
.util-fill{position:absolute;left:0;top:0;bottom:0;background:var(--red);border-radius:4px}
.util-fill.over{background:repeating-linear-gradient(45deg,var(--red),var(--red) 5px,var(--gold) 5px,var(--gold) 10px)}
.util-num{font-size:10.5px;font-weight:700;color:var(--gray11);min-width:30px;text-align:right}
.util-num.over{color:var(--red)}
.grp .g-track{position:relative;flex:0 0 auto;background:var(--f2)}

.row{display:flex;width:100%;height:var(--rowH);align-items:stretch;border-bottom:1px solid #ededed}
.row:hover .r-label{background:#fbf3f6}
.r-label{position:sticky;left:0;z-index:15;width:var(--leftW);flex:0 0 var(--leftW);background:var(--white);border-right:1.5px solid var(--gray11);display:flex;align-items:center;gap:7px;padding:0 12px 0 22px;cursor:pointer}
.r-label:hover{background:#fbf3f6}
.r-dot{width:8px;height:8px;border-radius:2px;flex:0 0 auto}
.r-name{font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1}
.r-client{font-size:9.5px;font-weight:700;color:var(--gray);letter-spacing:.03em;text-transform:uppercase;flex:0 0 auto}
.r-track{position:relative;flex:0 0 auto}

/* month bands inside body */
.band{position:absolute;top:0;bottom:0;border-left:1px solid #f0f0f0;pointer-events:none}
.band.alt{background:var(--f9)}
.todayline{position:absolute;top:0;bottom:0;width:2px;background:var(--red);z-index:8;pointer-events:none}
.todaycap{position:absolute;z-index:40;transform:translateX(-50%);background:var(--red);color:#fff;font-size:9px;font-weight:700;letter-spacing:.1em;padding:2px 6px;border-radius:4px;white-space:nowrap;text-transform:uppercase}

/* bars */
.bar{position:absolute;height:20px;top:7px;border-radius:5px;background:var(--red);color:#fff;display:flex;align-items:center;padding:0 8px;font-size:10.5px;font-weight:600;cursor:pointer;box-shadow:0 1px 2px rgba(0,0,0,.16);user-select:none;overflow:visible;white-space:nowrap}
.bar .bar-txt{overflow:hidden;text-overflow:ellipsis}
.bar.tender{background:var(--gold);color:#3a2f00}
.bar.dc{background:var(--gray11)}
.bar:hover{filter:brightness(1.06)}
.bar.dragging{filter:brightness(1.1);box-shadow:0 4px 14px rgba(0,0,0,.28);z-index:12}
.bar .util-chip{margin-left:6px;background:rgba(255,255,255,.24);border-radius:3px;padding:0 4px;font-weight:700;font-size:9.5px}
.bar.tender .util-chip{background:rgba(0,0,0,.14)}
.handle{position:absolute;top:0;bottom:0;width:7px;cursor:ew-resize;z-index:3}
.handle.l{left:-1px}.handle.r{right:-1px}
.bar .edit-btn{position:absolute;top:-9px;right:-9px;width:18px;height:18px;border-radius:50%;background:#fff;border:1px solid var(--line);display:none;align-items:center;justify-content:center;box-shadow:var(--sh);cursor:pointer}
.bar:hover .edit-btn{display:flex}
.bar .edit-btn svg{width:10px;height:10px}

/* milestone diamonds */
.ms{position:absolute;width:12px;height:12px;transform:translate(-50%,-50%) rotate(45deg);top:17px;border:1.5px solid #fff;z-index:10;cursor:help}
.ms.m15{background:#fff;border-color:var(--red)}
.ms.m45{background:var(--peach);border-color:var(--red)}
.ms.m85{background:var(--red);border-color:#fff}

/* calala plan cue */
.cable-pill{position:absolute;top:-8px;left:0;background:var(--ink);color:#fff;font-size:8.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:2px 6px;border-radius:4px;display:inline-flex;align-items:center;gap:4px;z-index:11;white-space:nowrap;box-shadow:0 1px 3px rgba(0,0,0,.25)}
.cable-pill .dia{width:6px;height:6px;background:var(--gold);transform:rotate(45deg)}

.tbc{position:absolute;height:20px;top:7px;left:6px;border:1.5px dashed var(--gray);border-radius:5px;background:repeating-linear-gradient(45deg,#fafafa,#fafafa 6px,#f0f0f0 6px,#f0f0f0 12px);color:var(--gray11);display:flex;align-items:center;padding:0 9px;font-size:10px;font-weight:600;cursor:pointer;white-space:nowrap}
.tbc:hover{border-color:var(--red);color:var(--red)}

/* ---------- Tooltip ---------- */
.tip{position:fixed;z-index:140;background:var(--ink);color:#fff;font-size:11px;font-weight:500;padding:7px 10px;border-radius:7px;pointer-events:none;box-shadow:var(--sh);max-width:240px;opacity:0;transition:opacity .1s}
.tip b{color:var(--peach)}
@media (prefers-reduced-motion:reduce){.tip{transition:none}}

/* ---------- Context menu ---------- */
.ctx{position:fixed;z-index:210;background:#fff;border:1px solid var(--line);border-radius:10px;box-shadow:0 12px 34px rgba(0,0,0,.22);padding:5px;min-width:180px;display:none}
.ctx.show{display:block}
.ctx-head{font-size:9.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gray);padding:6px 10px 4px}
.ctx button{display:flex;align-items:center;gap:9px;width:100%;border:0;background:none;text-align:left;padding:8px 10px;font-family:inherit;font-size:13px;font-weight:600;color:var(--ink);border-radius:7px;cursor:pointer}
.ctx button:hover{background:var(--f2)}
.ctx button.danger{color:var(--red)}
.ctx button.danger:hover{background:#fbeef2}
.ctx .ic{width:14px;height:14px;flex:0 0 14px;color:var(--gray11)}
.ctx button.danger .ic{color:var(--red)}

/* ---------- Drawer (Calala) ---------- */
.scrim{position:fixed;inset:0;background:rgba(0,0,0,.34);z-index:150;opacity:0;pointer-events:none;transition:opacity .18s}
.scrim.show{opacity:1;pointer-events:auto}
.drawer{position:fixed;top:0;right:0;height:100%;width:min(560px,94vw);background:var(--white);z-index:160;box-shadow:-8px 0 40px rgba(0,0,0,.22);transform:translateX(100%);transition:transform .22s ease;display:flex;flex-direction:column}
.drawer.show{transform:none}
@media (prefers-reduced-motion:reduce){.scrim,.drawer{transition:none}}
.dr-head{padding:20px 22px 16px;border-bottom:1px solid var(--line);position:relative}
.dr-head .eyebrow{color:var(--red)}
.dr-head h2{margin:4px 0 2px;font-size:20px;font-weight:800;letter-spacing:-.01em}
.dr-head .sub{font-size:12px;color:var(--gray11)}
.dr-close{position:absolute;top:16px;right:16px;width:32px;height:32px;border-radius:8px;border:1px solid var(--line);background:#fff;cursor:pointer;font-size:16px;color:var(--gray11);line-height:1}
.dr-close:hover{background:var(--f2)}
.dr-body{overflow:auto;padding:18px 22px 30px}
.dr-note{background:var(--peach-lt);border-left:3px solid var(--red);padding:10px 12px;border-radius:0 6px 6px 0;font-size:12px;color:var(--gray11);margin-bottom:18px}

.mini{border:1px solid var(--line);border-radius:10px;padding:12px 12px 6px;margin-bottom:20px;background:var(--f9);overflow-x:auto}
.mini-title{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--gray);margin-bottom:10px}
.mini-scale{position:relative;height:16px;margin-bottom:4px}
.mini-mtick{position:absolute;font-size:9px;color:var(--gray);border-left:1px solid var(--line);padding-left:3px;top:0;bottom:0}
.mini-row{position:relative;height:24px}
.mini-bar{position:absolute;height:15px;top:3px;border-radius:4px;display:flex;align-items:center;padding:0 6px;font-size:9px;font-weight:700;color:#fff;white-space:nowrap;overflow:hidden}
.mini-bar.firm{background:var(--red)}
.mini-bar.investigating{background:var(--gold);color:#3a2f00}
.mini-bar.pending{background:repeating-linear-gradient(45deg,#b9b9b9,#b9b9b9 5px,#cfcfcf 5px,#cfcfcf 10px);color:#333}
.mini-today{position:absolute;top:0;bottom:0;width:2px;background:var(--red);opacity:.6}

.seq{list-style:none;margin:0;padding:0;counter-reset:s}
.seq li{display:grid;grid-template-columns:30px 1fr;gap:12px;padding:12px 0;border-bottom:1px solid var(--line)}
.seq li:last-child{border-bottom:0}
.seq .n{width:28px;height:28px;border-radius:50%;background:var(--ink);color:#fff;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center}
.seq .n.firm{background:var(--red)}
.seq .d{font-size:13px;font-weight:700}
.seq .t{font-size:12px;color:var(--red);font-weight:700;margin-top:1px}
.seq .st{display:inline-block;font-size:9px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:2px 7px;border-radius:20px;margin-top:5px}
.st.firm{background:var(--red);color:#fff}
.st.investigating{background:var(--gold);color:#3a2f00}
.st.pending{background:var(--f2);color:var(--gray11);border:1px solid var(--line)}
.seq .note{font-size:11.5px;color:var(--gray11);margin-top:6px;line-height:1.4}

/* ---------- Modal (add/edit) ---------- */
.modal{position:fixed;inset:0;z-index:170;display:none;align-items:flex-start;justify-content:center;padding:40px 16px;overflow:auto;background:rgba(0,0,0,.34)}
.modal.show{display:flex}
.modal-card{background:#fff;width:min(560px,100%);border-radius:14px;box-shadow:0 20px 60px rgba(0,0,0,.3);position:relative}
.modal-head{padding:18px 22px;border-bottom:1px solid var(--line)}
.modal-head .eyebrow{color:var(--red)}
.modal-head h2{margin:3px 0 0;font-size:19px;font-weight:800}
.modal-body{padding:18px 22px}
.field{margin-bottom:14px}
.field label{display:block;font-size:10.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--gray11);margin-bottom:5px}
.field input,.field select{width:100%;padding:9px 11px;border:1px solid var(--line);border-radius:8px;font-family:inherit;font-size:13px;color:var(--ink);background:#fff}
.field input:focus,.field select:focus{border-color:var(--red);outline:none;box-shadow:var(--focus)}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
.hint{font-size:10.5px;color:var(--gray);margin-top:-8px;margin-bottom:12px}
.ms-fieldset{border:1px solid var(--line);border-radius:10px;padding:12px 14px 2px;margin-bottom:6px}
.ms-fieldset legend{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gray);padding:0 6px}
.modal-foot{padding:14px 22px;border-top:1px solid var(--line);display:flex;gap:10px;align-items:center}
.modal-foot .spacer{flex:1}
.link-danger{background:none;border:0;color:var(--red);font-weight:600;font-size:12px;cursor:pointer;padding:6px}
.link-danger:hover{text-decoration:underline}

.empty{padding:40px;text-align:center;color:var(--gray)}

/* ---------- Look-ahead sheet ---------- */
.sheet{position:fixed;top:50%;left:50%;transform:translate(-50%,-46%);width:min(880px,94vw);max-height:88vh;background:#fff;border-radius:16px;box-shadow:0 30px 80px rgba(0,0,0,.34);z-index:180;display:none;flex-direction:column;opacity:0}
.sheet.show{display:flex;opacity:1;transform:translate(-50%,-50%);transition:opacity .16s ease,transform .18s ease}
@media (prefers-reduced-motion:reduce){.sheet.show{transition:none}}
.sheet-head{padding:20px 24px 16px;border-bottom:1px solid var(--line);position:relative}
.sheet-head .eyebrow{color:var(--red)}
.sheet-head h2{margin:4px 0 0;font-size:21px;font-weight:800;letter-spacing:-.01em}
.sheet-body{overflow:auto;padding:8px 12px 20px}

.la-cablewrap{margin:10px 12px 6px;background:var(--peach-lt);border-radius:12px;padding:12px 14px}
.la-cablewrap .la-ct{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--red);margin-bottom:8px;display:flex;align-items:center;gap:7px}
.la-cablewrap .la-cd{width:8px;height:8px;background:var(--red);transform:rotate(45deg)}
.la-cable-item{font-size:12px;color:var(--gray11);padding:3px 0;display:flex;gap:8px}
.la-cable-item b{color:var(--ink);font-weight:700}
.la-cable-item .w{color:var(--red);font-weight:700;white-space:nowrap}

.la-weekhdr{display:grid;grid-template-columns:200px repeat(4,1fr) 74px;gap:8px;padding:8px 16px 6px;position:sticky;top:0;background:#fff;z-index:2}
.la-weekhdr div{font-size:9.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--gray);text-align:center}
.la-weekhdr div:first-child{text-align:left}
.la-row{display:grid;grid-template-columns:200px repeat(4,1fr) 74px;gap:8px;padding:10px 16px;border-top:1px solid var(--line);align-items:center}
.la-row:hover{background:var(--f9)}
.la-name{font-size:13px;font-weight:700}
.la-name .sub{font-size:10.5px;font-weight:600;color:var(--gray);margin-top:1px}
.la-cell{position:relative;height:38px;border-radius:6px;background:var(--f2);overflow:hidden;display:flex;align-items:flex-end;justify-content:center}
.la-bar{position:absolute;left:0;right:0;bottom:0;background:var(--red)}
.la-bar.over{background:repeating-linear-gradient(45deg,var(--red),var(--red) 5px,var(--gold) 5px,var(--gold) 10px)}
.la-bar.zero{background:var(--line)}
.la-pct{position:relative;z-index:1;font-size:10.5px;font-weight:700;padding-bottom:3px;color:#fff;text-shadow:0 1px 1px rgba(0,0,0,.35)}
.la-pct.low{color:var(--gray11);text-shadow:none}
.la-peak{text-align:center;font-size:15px;font-weight:800}
.la-peak.over{color:var(--red)}
.la-peak .pl{display:block;font-size:8.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--gray)}
.la-flags{grid-column:1 / -1;display:flex;flex-wrap:wrap;gap:6px;padding:2px 0 0}
.la-flag{font-size:10.5px;font-weight:600;padding:2px 8px;border-radius:20px;background:var(--f2);color:var(--gray11);border:1px solid var(--line)}
.la-flag.ms{background:#fff;border-color:var(--red);color:var(--red)}
.la-flag.end{background:var(--peach-lt);border-color:var(--peach);color:#7d4a1f}
.la-flag.start{background:#eef7ee;border-color:#bcdcbc;color:#2f6b2f}
.la-legend{font-size:10.5px;color:var(--gray);padding:10px 16px 2px;display:flex;gap:16px;flex-wrap:wrap}
@media (max-width:640px){
  .la-weekhdr,.la-row{grid-template-columns:120px repeat(4,1fr) 54px}
}@media (max-width:640px){
  .mast h1{font-size:18px}
  :root{--leftW:150px}
  .legend{display:none}
}
</style>
</head>
<body>

<div class="mast">
  <span class="mark" aria-hidden="true"><img src="data:image/png;base64,…LOGO…" alt="Consolidated Power Projects" width="62" height="45"></span>
  <div class="mast-txt">
    <span class="eyebrow">Resourcing line · QLD Design</span>
    <h1>Primary Design Team <b>Resource Schedule</b></h1>
  </div>
  <div class="mast-spacer"></div>
  <div class="mast-meta">
    <div><b id="todayLabel"></b></div>
    <div id="countLabel"></div>
  </div>
