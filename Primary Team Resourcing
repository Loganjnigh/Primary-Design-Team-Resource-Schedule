<script>
"use strict";
/* ============================================================
   CPP Primary Design Team — Resource Schedule
   Self-contained. State lives in memory; Save/Load via JSON.
   (localStorage used opportunistically, wrapped so it never
   breaks when unavailable.)
   ============================================================ */

/* ---------- date helpers ---------- */
const DAY = 86400000;
function d(iso){ if(!iso) return null; const p=iso.split('-'); return new Date(+p[0], +p[1]-1, +p[2], 12,0,0,0); }
function iso(dt){ if(!dt) return null; const y=dt.getFullYear(), m=String(dt.getMonth()+1).padStart(2,'0'), da=String(dt.getDate()).padStart(2,'0'); return `${y}-${m}-${da}`; }
function addDays(dt,n){ const x=new Date(dt); x.setDate(x.getDate()+n); return x; }
function daysBetween(a,b){ return Math.round((b-a)/DAY); }
const MONTHS=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
function fmt(dt){ return dt? `${dt.getDate()} ${MONTHS[dt.getMonth()]} ${String(dt.getFullYear()).slice(2)}`:'—'; }
function startOfMonth(dt){ return new Date(dt.getFullYear(),dt.getMonth(),1,12); }
function endOfMonth(dt){ return new Date(dt.getFullYear(),dt.getMonth()+1,0,12); }

/* ---------- seed data (from dates.xlsx) ---------- */
const DON={m15:'2026-06-01',m45:'2026-07-27',m85:'2026-09-16',start:'2026-05-08',end:'2026-10-23'};
const YAB={m15:'2026-03-04',m45:'2026-04-20',m85:'2026-06-04',start:'2026-02-13',end:'2026-07-10'};
const MEL={start:'2026-07-13',end:'2026-11-13'};
const SYN={start:'2026-06-01',end:'2026-08-20'};

const SEED=[
  {name:'Sean Leen',projects:[
    {name:'Yabulu Grid Connection',client:'Powerlink',type:'Project',util:40,...YAB},
    {name:'Beryl Substation',client:'Transgrid',type:'Project',util:10,start:null,end:null},
    {name:'MEL2 Datacentre',client:'AirTrunk',type:'Project',util:40,...MEL},
  ]},
  {name:'Armin Lahij',projects:[
    {name:'Yabulu Grid Connection',client:'Powerlink',type:'Project',util:20,...YAB},
    {name:'Don River Switchyard',client:'Powerlink',type:'Project',util:60,...DON},
    {name:'Syncon Tender',client:'Powerlink',type:'Tender',util:20,...SYN},
  ]},
  {name:'Ryan Rees',projects:[
    {name:'Don River Switchyard',client:'Powerlink',type:'Project',util:20,...DON},
    {name:'MEL2 Datacentre',client:'AirTrunk',type:'Project',util:70,...MEL},
    {name:'Syncon Tender',client:'Powerlink',type:'Tender',util:10,...SYN},
    {name:'Accelerated Syncon Project',client:'Transgrid',type:'Project',util:0,start:null,end:null},
  ]},
  {name:'Tim Sporne',projects:[
    {name:'Don River Switchyard',client:'Powerlink',type:'Project',util:100,...DON},
  ]},
  {name:'Adeel Javaid',projects:[
    {name:'NextDC Sydney West',client:'Transgrid',type:'Project',util:60,start:'2025-11-28',end:'2026-07-02'},
    {name:'Accelerated Syncon Project',client:'Transgrid',type:'Project',util:10,start:null,end:null},
    {name:'MEL2 Datacentre',client:'AirTrunk',type:'Project',util:30,...MEL},
  ]},
  {name:'Samira Rafiee',projects:[
    {name:'Don River Switchyard',client:'Powerlink',type:'Project',util:100,...DON},
  ]},
  {name:'Brendan McHugh',projects:[
    {name:'Calala BESS 330kV Cable',client:'Equis',type:'Project',util:30,start:'2025-01-12',end:'2026-12-20',cablePlan:true},
    {name:'MEL2 Datacentre',client:'AirTrunk',type:'Project',util:50,...MEL},
    {name:'Tuckeroo BESS GC',client:'Powerlink',type:'Project',util:20,start:'2026-07-13',end:'2026-07-31'},
  ]},
  {name:'Ben Pyne',projects:[
    {name:'Don River Switchyard',client:'Powerlink',type:'Project',util:100,...DON},
  ]},
];

/* Calala cable install/termination sequence (from dates.xlsx rows 27-33) */
const CABLE=[
  {n:1,desc:'Calala BESS → JB2 — Cable Pull',timing:'27 Jul – 29 Jul',status:'firm',note:'Firm — this has been planned.',s:'2026-07-27',e:'2026-07-29'},
  {n:2,desc:'Calala BESS — Termination',timing:'10 Aug – 20 Aug',status:'firm',note:'Firm — this has been planned.',s:'2026-08-10',e:'2026-08-20'},
  {n:3,desc:'JB1 → JB2 — Cable Pull',timing:'Mid Aug – Early Sept',status:'investigating',note:'Investigating options to complete these works without access from Burgmanns Lane.',s:'2026-08-15',e:'2026-09-07'},
  {n:4,desc:'JB2 — Jointing',timing:'Mid Sept',status:'pending',note:'Pending whether CableGrid can fit this in.',s:'2026-09-12',e:'2026-09-18'},
  {n:5,desc:'Tamworth → JB1 — Cable Pull',timing:'Late Oct – Early Nov',status:'pending',note:'Pending modification management plan approval from Equis.',s:'2026-10-26',e:'2026-11-06'},
  {n:6,desc:'JB1 — Jointing',timing:'Mid Nov',status:'pending',note:'Pending modification management plan approval from Equis.',s:'2026-11-12',e:'2026-11-18'},
  {n:7,desc:'Tamworth — Termination',timing:'End Nov – Early Dec',status:'pending',note:'Pending modification management plan approval from Equis.',s:'2026-11-26',e:'2026-12-06'},
];

/* ---------- state ---------- */
let state=null;
let uid=1;
function hydrate(raw){
  state={members:raw.map(m=>({
    id:'m'+(uid++), name:m.name,
    projects:m.projects.map(p=>({id:'p'+(uid++),cablePlan:false,m15:null,m45:null,m85:null,...p}))
  }))};
}
const LS_KEY='cpp_resource_schedule_v1';
function persist(){ try{ localStorage.setItem(LS_KEY, JSON.stringify(exportData())); }catch(e){/* ignore */} }
function tryRestore(){
  try{ const s=localStorage.getItem(LS_KEY); if(s){ const raw=JSON.parse(s); if(raw&&raw.members){ hydrate(raw.members); return true; } } }catch(e){}
  return false;
}
function exportData(){
  return {app:'CPP Primary Design Team Resource Schedule',saved:new Date().toISOString(),
    members:state.members.map(m=>({name:m.name,projects:m.projects.map(p=>({
      name:p.name,client:p.client,type:p.type,util:p.util,start:p.start,end:p.end,
      m15:p.m15,m45:p.m45,m85:p.m85,cablePlan:!!p.cablePlan
    }))}))};
}

/* ---------- zoom / domain ---------- */
const ZOOM={week:26,month:7.4,quarter:2.7};
let zoom='month';
let ppd=ZOOM[zoom];
let domainStart, domainEnd, domainDays;

function computeDomain(){
  let min=null,max=null;
  state.members.forEach(m=>m.projects.forEach(p=>{
    [p.start,p.end,p.m15,p.m45,p.m85].forEach(v=>{ const dt=d(v); if(dt){ if(!min||dt<min)min=dt; if(!max||dt>max)max=dt; }});
  }));
  const today=new Date(); today.setHours(12,0,0,0);
  if(!min) min=addDays(today,-30); if(!max) max=addDays(today,120);
  if(today<min)min=today; if(today>max)max=today;
  // include cable sequence range
  CABLE.forEach(c=>{ const s=d(c.s),e=d(c.e); if(s<min)min=s; if(e>max)max=e; });
  domainStart=startOfMonth(addDays(min,-6));
  domainEnd=endOfMonth(addDays(max,6));
  domainDays=daysBetween(domainStart,domainEnd)+1;
}
function xOf(dt){ return daysBetween(domainStart,dt)*ppd; }
function dateAtX(x){ return addDays(domainStart, Math.round(x/ppd)); }
function timelineWidth(){ return domainDays*ppd; }

/* ---------- rendering ---------- */
const el=id=>document.getElementById(id);
const taxis=el('taxis'), rows=el('rows'), viewport=el('viewport'), board=el('board');

function monthCells(){
  const cells=[]; let cur=startOfMonth(domainStart); let i=0;
  while(cur<=domainEnd){
    const w=(endOfMonth(cur).getDate())*ppd;
    cells.push({left:xOf(cur),width:w,label:`${MONTHS[cur.getMonth()]} ${String(cur.getFullYear()).slice(2)}`,alt:i%2===1,date:new Date(cur)});
    cur=new Date(cur.getFullYear(),cur.getMonth()+1,1,12); i++;
  }
  return cells;
}

function renderAxis(){
  const w=timelineWidth();
  taxis.style.width=w+'px';
  taxis.innerHTML='';
  const cells=monthCells();
  cells.forEach(c=>{
    const m=document.createElement('div');
    m.className='month'+(c.alt?' alt':'');
    m.style.left=c.left+'px'; m.style.width=c.width+'px';
    m.innerHTML=`<span class="m-name">${c.label}</span>`;
    taxis.appendChild(m);
  });
  if(zoom==='week'){
    // week ticks (Mondays)
    let cur=new Date(domainStart); 
    while(cur.getDay()!==1) cur=addDays(cur,1);
    while(cur<=domainEnd){
      const wk=document.createElement('div');
      wk.className='week'; wk.style.left=xOf(cur)+'px';
      wk.textContent=`${cur.getDate()}/${cur.getMonth()+1}`;
      taxis.appendChild(wk); cur=addDays(cur,7);
    }
  }
}

function bands(container){
  const cells=monthCells();
  cells.forEach(c=>{
    const b=document.createElement('div');
    b.className='band'+(c.alt?' alt':'');
    b.style.left=c.left+'px'; b.style.width=c.width+'px';
    container.appendChild(b);
  });
}
function todayMarker(container,withCap){
  const t=new Date(); t.setHours(12,0,0,0);
  if(t<domainStart||t>domainEnd) return;
  const line=document.createElement('div');
  line.className='todayline'; line.style.left=xOf(t)+'px';
  container.appendChild(line);
}

function memberUtil(m){ return m.projects.reduce((s,p)=>s+(+p.util||0),0); }

function render(){
  computeDomain();
  ppd=ZOOM[zoom];
  renderAxis();
  const w=timelineWidth();
  board.style.width=`calc(var(--leftW) + ${w}px)`;
  rows.innerHTML='';
  hideTip();
  el('countLabel').textContent=`${state.members.length} people · ${state.members.reduce((s,m)=>s+m.projects.length,0)} allocations`;

  state.members.forEach(m=>{
    // group header
    const grp=document.createElement('div'); grp.className='grp';
    const gl=document.createElement('div'); gl.className='g-label';
    const util=memberUtil(m); const over=util>100;
    const collapsed=!!m._collapsed;
    gl.innerHTML=`
      <div class="g-name">
        <button class="chev ${collapsed?'closed':''}" aria-label="${collapsed?'Expand':'Collapse'} ${escapeHtml(m.name)}" aria-expanded="${!collapsed}">
          <svg viewBox="0 0 10 10"><path d="M2 3.5L5 6.5L8 3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <span class="g-nm">${escapeHtml(m.name)}</span>
        <span class="cap">${m.projects.length}</span>
      </div>
      <div class="util">
        <div class="util-track"><div class="util-fill ${over?'over':''}" style="width:${Math.min(util,100)}%"></div></div>
        <div class="util-num ${over?'over':''}">${util}%</div>
      </div>`;
    const gt=document.createElement('div'); gt.className='g-track'; gt.style.width=w+'px';
    bands(gt); todayMarker(gt);
    grp.appendChild(gl); grp.appendChild(gt); rows.appendChild(grp);
    const toggle=()=>{ m._collapsed=!m._collapsed; render(); };
    gl.addEventListener('click',toggle);
    const addMenu=e=>showCtx(e,m.name,[{label:'Add project',icon:'add',fn:()=>openAdd(m)},{label:m._collapsed?'Expand':'Collapse',icon:'edit',fn:toggle}]);
    gl.addEventListener('contextmenu',addMenu);
    gt.addEventListener('contextmenu',addMenu);

    // project rows
    if(!m._collapsed) m.projects.forEach(p=>{
      const row=document.createElement('div'); row.className='row';
      const rl=document.createElement('div'); rl.className='r-label';
      const col=barColor(p);
      rl.innerHTML=`<span class="r-dot" style="background:${col}"></span>
        <span class="r-name" title="${escapeHtml(p.name)}">${escapeHtml(p.name)}</span>
        <span class="r-client">${escapeHtml(p.client||'')}</span>`;
      rl.addEventListener('click',()=> p.cablePlan? openCable() : openEdit(m,p));
      rl.addEventListener('contextmenu',e=>projectMenu(e,m,p));
      const rt=document.createElement('div'); rt.className='r-track'; rt.style.width=w+'px';
      bands(rt); todayMarker(rt);
      renderBar(rt,m,p);
      row.appendChild(rl); row.appendChild(rt); rows.appendChild(row);
    });
  });

  addTodayCap();
  syncCollapseBtn();
}

function addTodayCap(){
  const t=new Date(); t.setHours(12,0,0,0);
  if(t<domainStart||t>domainEnd) return;
  const cap=document.createElement('div'); cap.className='todaycap';
  cap.textContent='Today';
  cap.style.left=xOf(t)+'px'; cap.style.top='34px';
  taxis.appendChild(cap); // rides with the axis; taxis is cleared each render
}

function barColor(p){
  return p.type==='Tender' ? 'var(--gold)' : 'var(--red)';
}
function barClass(p){
  return p.type==='Tender' ? 'tender' : '';
}

function renderBar(track,m,p){
  const s=d(p.start), e=d(p.end);
  if(!s||!e){
    const tbc=document.createElement('div'); tbc.className='tbc';
    tbc.textContent='Dates TBC — set';
    tbc.title='No dates yet — click to schedule';
    tbc.addEventListener('click',()=>openEdit(m,p));
    tbc.addEventListener('contextmenu',e=>projectMenu(e,m,p));
    track.appendChild(tbc);
    return;
  }
  const left=xOf(s), width=Math.max(daysBetween(s,e)*ppd, 14);
  const bar=document.createElement('div');
  bar.className='bar '+barClass(p);
  bar.style.left=left+'px'; bar.style.width=width+'px';
  bar.innerHTML=`<span class="bar-txt">${escapeHtml(p.name)}</span><span class="util-chip">${p.util}%</span>`;

  // resize handles
  const hl=document.createElement('div'); hl.className='handle l';
  const hr=document.createElement('div'); hr.className='handle r';
  bar.appendChild(hl); bar.appendChild(hr);

  // edit affordance
  const eb=document.createElement('div'); eb.className='edit-btn'; eb.title='Edit';
  eb.innerHTML='<svg viewBox="0 0 12 12"><path d="M8.5 1.5l2 2L4 10l-2.5.5L2 8z" fill="none" stroke="#9E053B" stroke-width="1.3"/></svg>';
  eb.addEventListener('click',ev=>{ev.stopPropagation();openEdit(m,p);});
  bar.appendChild(eb);

  // cable plan pill
  if(p.cablePlan){
    const pill=document.createElement('div'); pill.className='cable-pill';
    pill.innerHTML='<span class="dia"></span>Cable plan ▸';
    pill.title='View cable install & termination windows';
    pill.addEventListener('click',ev=>{ev.stopPropagation();openCable();});
    bar.appendChild(pill);
  }

  // milestones
  addMs(track,left,s,p.m15,'m15','15% submission');
  addMs(track,left,s,p.m45,'m45','45% submission');
  addMs(track,left,s,p.m85,'m85','85% submission');

  // interactions: click vs drag
  wireDrag(bar,m,p,hl,hr);
  bar.addEventListener('click',ev=>{
    if(bar._moved) return;
    if(p.cablePlan) openCable(); else openEdit(m,p);
  });
  bar.tabIndex=0;
  bar.addEventListener('keydown',ev=>{ if(ev.key==='Enter'||ev.key===' '){ev.preventDefault(); p.cablePlan?openCable():openEdit(m,p);} });
  bar.setAttribute('role','button');
  bar.setAttribute('aria-label',`${p.name}, ${p.util} percent, ${fmt(s)} to ${fmt(e)}`);
  bar.addEventListener('contextmenu',e=>projectMenu(e,m,p));

  track.appendChild(bar);
}

function addMs(track,barLeft,barStart,msIso,cls,label){
  const dt=d(msIso); if(!dt) return;
  const dot=document.createElement('div');
  dot.className='ms '+cls;
  dot.style.left=xOf(dt)+'px';
  dot.dataset.tip=`<b>${label}</b><br>${fmt(dt)}`;
  wireTip(dot);
  track.appendChild(dot);
}

/* ---------- drag & resize ---------- */
function wireDrag(bar,m,p,hl,hr){
  let mode=null,startX=0,os=null,oe=null,liveS=null,liveE=null;
  const dur=daysBetween(d(p.start),d(p.end));
  function down(e,which){
    if(e.button!==undefined && e.button!==0) return; // left button only
    if(p.cablePlan && which==='move'){ return; } // don't move calala by drag (protect the anchor project); still resizable
    mode=which; startX=e.clientX; os=d(p.start); oe=d(p.end); bar._moved=false;
    bar.classList.add('dragging');
    window.addEventListener('pointermove',move); window.addEventListener('pointerup',up);
    e.preventDefault(); e.stopPropagation();
  }
  function move(e){
    const dxDays=Math.round((e.clientX-startX)/ppd);
    if(Math.abs(e.clientX-startX)>3) bar._moved=true;
    if(mode==='move'){ liveS=addDays(os,dxDays); liveE=addDays(oe,dxDays); }
    else if(mode==='l'){ liveS=addDays(os,dxDays); if(daysBetween(liveS,oe)<1)liveS=addDays(oe,-1); liveE=oe; }
    else if(mode==='r'){ liveE=addDays(oe,dxDays); if(daysBetween(os,liveE)<1)liveE=addDays(os,1); liveS=os; }
    bar.style.left=xOf(liveS)+'px';
    bar.style.width=Math.max(daysBetween(liveS,liveE)*ppd,14)+'px';
  }
  function up(){
    window.removeEventListener('pointermove',move); window.removeEventListener('pointerup',up);
    bar.classList.remove('dragging');
    if(liveS&&liveE&&bar._moved){ p.start=iso(liveS); p.end=iso(liveE); persist(); render(); }
    liveS=liveE=null; setTimeout(()=>{bar._moved=false;},0);
  }
  bar.addEventListener('pointerdown',e=>{ if(e.target===hl||e.target===hr)return; if(e.target.closest('.edit-btn')||e.target.closest('.cable-pill'))return; down(e,'move'); });
  hl.addEventListener('pointerdown',e=>down(e,'l'));
  hr.addEventListener('pointerdown',e=>down(e,'r'));
}

/* ---------- tooltip ---------- */
const tip=el('tip');
function wireTip(node){
  node.addEventListener('mouseenter',e=>{ tip.innerHTML=node.dataset.tip; tip.style.opacity='1'; posTip(e); });
  node.addEventListener('mousemove',posTip);
  node.addEventListener('mouseleave',()=>{ tip.style.opacity='0'; });
}
function posTip(e){ tip.style.left=(e.clientX+14)+'px'; tip.style.top=(e.clientY+14)+'px'; }
function hideTip(){ tip.style.opacity='0'; }

/* ---------- context menu ---------- */
const ctx=el('ctxMenu');
const ICN={
  add:'<svg class="ic" viewBox="0 0 14 14"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>',
  edit:'<svg class="ic" viewBox="0 0 14 14"><path d="M9.5 2l2.5 2.5L5 11.5 2 12l.5-3z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>',
  del:'<svg class="ic" viewBox="0 0 14 14"><path d="M3 4h8M5.5 4V2.7h3V4M4 4l.6 8h4.8L10 4" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  cable:'<svg class="ic" viewBox="0 0 14 14"><path d="M7 1.5 12.5 7 7 12.5 1.5 7z" fill="none" stroke="currentColor" stroke-width="1.3"/></svg>'
};
function showCtx(e,title,items){
  e.preventDefault();
  ctx.innerHTML = (title?`<div class="ctx-head">${escapeHtml(title)}</div>`:'') +
    items.map((it,i)=>`<button data-i="${i}" class="${it.danger?'danger':''}">${ICN[it.icon]||''}<span>${escapeHtml(it.label)}</span></button>`).join('');
  ctx.querySelectorAll('button').forEach(b=>b.addEventListener('click',()=>{ hideCtx(); items[+b.dataset.i].fn(); }));
  ctx.classList.add('show');
  const mw=ctx.offsetWidth, mh=ctx.offsetHeight;
  let x=e.clientX, y=e.clientY;
  if(x+mw>innerWidth-8) x=innerWidth-mw-8;
  if(y+mh>innerHeight-8) y=innerHeight-mh-8;
  ctx.style.left=x+'px'; ctx.style.top=y+'px';
}
function hideCtx(){ ctx.classList.remove('show'); }
window.addEventListener('click',hideCtx);
window.addEventListener('scroll',hideCtx,true);
window.addEventListener('resize',hideCtx);
document.addEventListener('keydown',e=>{ if(e.key==='Escape') hideCtx(); });

function projectMenu(e,m,p){
  const items=[{label:'Edit allocation',icon:'edit',fn:()=>openEdit(m,p)}];
  if(p.cablePlan) items.unshift({label:'View cable plan',icon:'cable',fn:openCable});
  items.push({label:'Delete allocation',icon:'del',danger:true,fn:()=>removeProject(m,p)});
  showCtx(e,p.name,items);
}
function removeProject(m,p){
  if(!confirm(`Delete “${p.name}” from ${m.name}?`)) return;
  m.projects=m.projects.filter(x=>x!==p);
  cleanupEmptyMembers(); persist(); render();
}

/* ---------- Calala drawer ---------- */
function openCable(){
  hideTip(); hideCtx();
  const body=el('drBody');
  // mini gantt aligned Jul–Dec 2026
  const mS=d('2026-07-20'), mE=d('2026-12-15');
  const totalDays=daysBetween(mS,mE);
  const pxW=Math.max(460, viewport.clientWidth*0.44);
  const scale=pxW/totalDays;
  const xm=dt=>daysBetween(mS,dt)*scale;

  let ticks='';
  let cur=startOfMonth(mS); if(cur<mS)cur=new Date(mS.getFullYear(),mS.getMonth()+1,1,12);
  while(cur<=mE){ ticks+=`<div class="mini-mtick" style="left:${xm(cur)}px">${MONTHS[cur.getMonth()]}</div>`; cur=new Date(cur.getFullYear(),cur.getMonth()+1,1,12); }

  let barsRows='';
  CABLE.forEach(c=>{
    const s=d(c.s),e=d(c.e);
    const left=Math.max(xm(s),0), wd=Math.max(daysBetween(s,e)*scale,10);
    barsRows+=`<div class="mini-row"><div class="mini-bar ${c.status}" style="left:${left}px;width:${wd}px" title="${c.desc} · ${c.timing}">${c.n}</div></div>`;
  });
  const t=new Date(); t.setHours(12,0,0,0);
  const todayEl=(t>=mS&&t<=mE)?`<div class="mini-today" style="left:${xm(t)}px"></div>`:'';

  let list='';
  CABLE.forEach(c=>{
    list+=`<li>
      <div class="n ${c.status==='firm'?'firm':''}">${c.n}</div>
      <div>
        <div class="d">${escapeHtml(c.desc)}</div>
        <div class="t">${escapeHtml(c.timing)}</div>
        <span class="st ${c.status}">${c.status==='firm'?'Firm':c.status==='investigating'?'Investigating':'Pending'}</span>
        <div class="note">${escapeHtml(c.note)}</div>
      </div>
    </li>`;
  });

  body.innerHTML=`
    <div class="dr-note">Two windows are <b>firm and planned</b> (steps 1–2). Steps 4–7 are indicative and pending CableGrid capacity or Equis MMP approval — treat the bars as approximate until confirmed.</div>
    <div class="mini">
      <div class="mini-title">Site windows · Jul – Dec 2026</div>
      <div style="position:relative;width:${pxW}px">
        <div class="mini-scale">${ticks}${todayEl}</div>
        ${barsRows}
      </div>
    </div>
    <ol class="seq">${list}</ol>`;

  el('scrim').classList.add('show');
  el('drawer').classList.add('show');
  el('drClose').focus();
}
function closeCable(){ el('scrim').classList.remove('show'); el('drawer').classList.remove('show'); }

/* ---------- add / edit modal ---------- */
let editing=null; // {m,p} or null for add
function fillMembers(sel){
  sel.innerHTML='';
  state.members.forEach(m=>{ const o=document.createElement('option'); o.value=m.id; o.textContent=m.name; sel.appendChild(o); });
  const o=document.createElement('option'); o.value='__new__'; o.textContent='+ New team member…'; sel.appendChild(o);
}
function openAdd(prefillMember){
  editing=null;
  el('modalEyebrow').textContent=prefillMember?prefillMember.name:'New allocation';
  el('modalTitle').textContent=prefillMember?`Add project · ${prefillMember.name}`:'Add project';
  el('btnDelete').style.display='none';
  fillMembers(el('fMember'));
  el('fMember').value = prefillMember ? prefillMember.id : (state.members[0]?state.members[0].id:'__new__');
  toggleNewMember();
  el('fName').value=''; el('fClient').value=''; el('fType').value='Project';
  el('fUtil').value=20; el('fStart').value=''; el('fEnd').value='';
  el('fM15').value=''; el('fM45').value=''; el('fM85').value='';
  showModal();
}
function openEdit(m,p){
  editing={m,p};
  el('modalEyebrow').textContent=m.name;
  el('modalTitle').textContent='Edit allocation';
  el('btnDelete').style.display='inline-block';
  fillMembers(el('fMember'));
  el('fMember').value=m.id; toggleNewMember();
  el('fName').value=p.name; el('fClient').value=p.client||''; el('fType').value=p.type||'Project';
  el('fUtil').value=p.util; el('fStart').value=p.start||''; el('fEnd').value=p.end||'';
  el('fM15').value=p.m15||''; el('fM45').value=p.m45||''; el('fM85').value=p.m85||'';
  showModal();
}
function toggleNewMember(){ el('newMemberWrap').style.display = el('fMember').value==='__new__'?'block':'none'; }
function showModal(){ hideTip(); hideCtx(); el('fName').style.borderColor=''; el('modal').classList.add('show'); setTimeout(()=>el('fName').focus(),30); }
function closeModal(){ el('modal').classList.remove('show'); }

function saveProj(){
  const name=el('fName').value.trim();
  if(!name){ el('fName').focus(); el('fName').style.borderColor='var(--red)'; return; }
  const data={
    name, client:el('fClient').value.trim(), type:el('fType').value,
    util:Math.max(0,Math.min(100,+el('fUtil').value||0)),
    start:el('fStart').value||null, end:el('fEnd').value||null,
    m15:el('fM15').value||null, m45:el('fM45').value||null, m85:el('fM85').value||null
  };
  // date sanity
  if(data.start&&data.end&&d(data.end)<d(data.start)){ const t=data.start; data.start=data.end; data.end=t; }

  let memberId=el('fMember').value, member;
  if(memberId==='__new__'){
    const nm=el('fNewMember').value.trim();
    if(!nm){ el('fNewMember').focus(); return; }
    member={id:'m'+(uid++),name:nm,projects:[]}; state.members.push(member);
  } else {
    member=state.members.find(m=>m.id===memberId);
  }

  if(editing){
    // if member changed, move it
    if(editing.m.id!==member.id){
      editing.m.projects=editing.m.projects.filter(x=>x!==editing.p);
      member.projects.push(editing.p);
    }
    Object.assign(editing.p,data);
  } else {
    member.projects.push({id:'p'+(uid++),cablePlan:false,...data});
  }
  cleanupEmptyMembers();
  persist(); closeModal(); render();
}
function deleteProj(){
  if(!editing) return;
  if(!confirm(`Delete “${editing.p.name}” from ${editing.m.name}?`)) return;
  editing.m.projects=editing.m.projects.filter(x=>x!==editing.p);
  cleanupEmptyMembers();
  persist(); closeModal(); render();
}
function cleanupEmptyMembers(){ state.members=state.members.filter(m=>m.projects.length>0); }

/* ---------- save / load ---------- */
function downloadJson(){
  const blob=new Blob([JSON.stringify(exportData(),null,2)],{type:'application/json'});
  const url=URL.createObjectURL(blob); const a=document.createElement('a');
  a.href=url; a.download='CPP-design-team-schedule.json'; a.click();
  setTimeout(()=>URL.revokeObjectURL(url),1000);
}
function loadJson(file){
  const r=new FileReader();
  r.onload=()=>{ try{ const raw=JSON.parse(r.result); if(raw&&raw.members){ hydrate(raw.members); persist(); render(); } else alert('That file doesn’t look like a saved schedule.'); }catch(e){ alert('Could not read that file.'); } };
  r.readAsText(file);
}

/* ---------- util ---------- */
function escapeHtml(s){ return String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function scrollToToday(){
  const t=new Date(); t.setHours(12,0,0,0);
  viewport.scrollLeft = Math.max(0, xOf(t) - viewport.clientWidth*0.35);
}

/* ---------- collapse all ---------- */
function setAllCollapsed(v){ state.members.forEach(m=>m._collapsed=v); render(); syncCollapseBtn(); }
function syncCollapseBtn(){
  const anyOpen=state.members.some(m=>!m._collapsed);
  el('btnCollapse').textContent=anyOpen?'Collapse all':'Expand all';
}

/* ---------- 4-week look-ahead ---------- */
function overlaps(s,e,a,b){ return s<=b && e>=a; }
function within(dt,a,b){ return dt>=a && dt<=b; }
function weeklyLoad(m,weeks){
  return weeks.map(([a,b])=>{
    let sum=0;
    m.projects.forEach(p=>{
      const s=d(p.start), e=d(p.end);
      const active = (!s||!e) ? true : overlaps(s,e,a,b);
      if(active) sum+=(+p.util||0);
    });
    return sum;
  });
}
function memberFlags(m,winA,winB){
  const flags=[];
  m.projects.forEach(p=>{
    [['15',p.m15],['45',p.m45],['85',p.m85]].forEach(([lab,v])=>{
      const dt=d(v); if(dt&&within(dt,winA,winB)) flags.push({cls:'ms',txt:`${p.name} · ${lab}% ${fmt(dt)}`});
    });
    const st=d(p.start), en=d(p.end);
    if(st&&within(st,winA,winB)) flags.push({cls:'start',txt:`${p.name} starts ${fmt(st)}`});
    if(en&&within(en,winA,winB)) flags.push({cls:'end',txt:`${p.name} ends ${fmt(en)}`});
  });
  return flags;
}
function openLook(){
  hideTip(); hideCtx();
  const today=new Date(); today.setHours(12,0,0,0);
  const winA=today, winB=addDays(today,27);
  const weeks=[0,1,2,3].map(i=>[addDays(today,i*7), addDays(today,i*7+6)]);
  el('lookRange').textContent=`Resourcing forecast · ${fmt(winA)} – ${fmt(winB)}`;

  // Calala site windows in range
  const cable=CABLE.filter(c=>overlaps(d(c.s),d(c.e),winA,winB));
  let cableHtml='';
  if(cable.length){
    cableHtml=`<div class="la-cablewrap"><div class="la-ct"><span class="la-cd"></span>Calala BESS · site windows in the next 4 weeks</div>`+
      cable.map(c=>`<div class="la-cable-item"><span class="w">${escapeHtml(c.timing)}</span><b>Step ${c.n}</b>${escapeHtml(c.desc)} <span style="color:var(--gray)">— ${c.status}</span></div>`).join('')+
      `</div>`;
  }

  // header
  let head=`<div class="la-weekhdr"><div>Team member</div>`;
  weeks.forEach(([a,b],i)=>{ head+=`<div>Wk${i+1}<br>${a.getDate()} ${MONTHS[a.getMonth()]}</div>`; });
  head+=`<div>Peak</div></div>`;

  // rows
  let body='';
  state.members.forEach(m=>{
    const load=weeklyLoad(m,weeks);
    const peak=Math.max(...load,0);
    const flags=memberFlags(m,winA,winB);
    let cells='';
    load.forEach(v=>{
      const over=v>100, h=Math.min(v,100);
      const low=v<45;
      cells+=`<div class="la-cell" title="${v}% allocated">
        <div class="la-bar ${over?'over':''} ${v===0?'zero':''}" style="height:${v===0?4:h}%"></div>
        <span class="la-pct ${low?'low':''}">${v===0?'—':v+'%'}</span>
      </div>`;
    });
    const activeCount=m.projects.filter(p=>{const s=d(p.start),e=d(p.end); return (!s||!e)?true:overlaps(s,e,winA,winB);}).length;
    body+=`<div class="la-row">
      <div><div class="la-name">${escapeHtml(m.name)}</div><div class="sub">${activeCount} active</div></div>
      ${cells}
      <div class="la-peak ${peak>100?'over':''}">${peak}%<span class="pl">peak</span></div>
      ${flags.length?`<div class="la-flags">${flags.map(f=>`<span class="la-flag ${f.cls}">${escapeHtml(f.txt)}</span>`).join('')}</div>`:''}
    </div>`;
  });

  const legend=`<div class="la-legend">
    <span>Weekly bar = total allocated utilisation that week</span>
    <span><span class="la-flag ms" style="padding:1px 7px">submission gate</span></span>
    <span><span class="la-flag start" style="padding:1px 7px">project starts</span></span>
    <span><span class="la-flag end" style="padding:1px 7px">project ends</span></span>
  </div>`;

  el('lookBody').innerHTML=cableHtml+head+body+legend;
  el('lookScrim').classList.add('show');
  el('look').classList.add('show');
  el('lookClose').focus();
}
function closeLook(){ el('lookScrim').classList.remove('show'); el('look').classList.remove('show'); }

/* ---------- wire up ---------- */
el('scaleSeg').addEventListener('click',e=>{
  const b=e.target.closest('button'); if(!b)return;
  [...el('scaleSeg').children].forEach(x=>x.classList.remove('on'));
  b.classList.add('on'); zoom=b.dataset.z; render(); if(zoom!=='quarter') scrollToToday();
});
el('btnToday').addEventListener('click',scrollToToday);
el('btnFit').addEventListener('click',()=>{ viewport.scrollLeft=0; });
el('btnCollapse').addEventListener('click',()=>{ const anyOpen=state.members.some(m=>!m._collapsed); setAllCollapsed(anyOpen); });
el('btnLook').addEventListener('click',openLook);
el('lookClose').addEventListener('click',closeLook);
el('lookScrim').addEventListener('click',closeLook);
el('btnAdd').addEventListener('click',()=>openAdd());
el('btnCancel').addEventListener('click',closeModal);
el('btnSaveProj').addEventListener('click',saveProj);
el('btnDelete').addEventListener('click',deleteProj);
el('fMember').addEventListener('change',toggleNewMember);
el('drClose').addEventListener('click',closeCable);
el('scrim').addEventListener('click',closeCable);
el('btnSave').addEventListener('click',downloadJson);
el('btnLoad').addEventListener('click',()=>el('fileInput').click());
el('fileInput').addEventListener('change',e=>{ if(e.target.files[0]) loadJson(e.target.files[0]); e.target.value=''; });
el('modal').addEventListener('click',e=>{ if(e.target===el('modal')) closeModal(); });
document.addEventListener('keydown',e=>{ if(e.key==='Escape'){ closeCable(); closeModal(); closeLook(); } });

/* ---------- boot ---------- */
(function init(){
  const t=new Date();
  el('todayLabel').textContent=`Today · ${t.getDate()} ${MONTHS[t.getMonth()]} ${t.getFullYear()}`;
  if(!tryRestore()) hydrate(SEED);
  render();
  scrollToToday();
})();
</script>
